# Copy this file to `.env` and fill in the values you need.

# Hugging Face access token for gated or authenticated model downloads.
HF_TOKEN=

# Optional. Set to a W&B project name if you want experiment tracking.
WANDB_PROJECT=gemma4-for-education
WANDB_ENTITY=

# Optional. Useful when running on a shared CUDA box.
CUDA_VISIBLE_DEVICES=0
PYTORCH_ALLOC_CONF=expandable_segments:True

# Optional output locations.
ADAPTER_OUTPUT_DIR=artifacts/adapters/first-run
EVAL_OUTPUT_PATH=artifacts/evals/first_run_eval.json
